<div class="container-sm py-16"
     data-controller="wechat-pay"
     data-wechat-pay-out-trade-no-value="<%= @out_trade_no %>"
     data-wechat-pay-success-url-value="<%= wechat_pay_order_success_path %>"
     data-wechat-pay-status-url-value="/wechat/pay/status">

  <div class="card text-center">
    <div class="card-header border-b border-[hsl(var(--color-border))]">
      <div class="flex items-center justify-center gap-2 mb-2">
        <%= lucide_icon "qr-code", class: "w-6 h-6 text-primary" %>
        <h1 class="text-xl font-semibold text-primary">微信扫码支付</h1>
      </div>
      <p class="text-sm text-secondary">请使用微信 App 扫描下方二维码</p>
    </div>

    <div class="card-body space-y-6">
      <%# QR Code %>
      <div class="flex justify-center">
        <div class="p-4 bg-white rounded-xl border-2 border-[hsl(var(--color-border))] inline-block">
          <%= @qr_svg.html_safe %>
        </div>
      </div>

      <%# Amount %>
      <div class="space-y-1">
        <div class="flex items-baseline justify-center gap-1">
          <span class="text-3xl font-bold text-primary font-mono">¥<%= sprintf("%.2f", @amount_yuan) %></span>
        </div>
        <p class="text-xs text-muted">青狮法律技能平台 · 试用体验</p>
      </div>

      <%# Status indicator %>
      <div class="flex items-center justify-center gap-3 py-3 px-4 rounded-lg bg-[hsl(var(--color-surface-elevated))]">
        <div data-wechat-pay-target="spinner"
             class="w-4 h-4 border-2 border-primary border-t-transparent rounded-full animate-spin">
        </div>
        <span data-wechat-pay-target="status" class="text-sm text-secondary font-mono">
          等待扫码支付...
        </span>
      </div>

      <%# Steps %>
      <ol class="text-left text-sm text-muted space-y-2 list-none">
        <li class="flex items-start gap-2">
          <%= lucide_icon "smartphone", class: "w-4 h-4 shrink-0 mt-0.5 text-primary" %>
          <span>打开微信，点击右上角「+」→「扫一扫」</span>
        </li>
        <li class="flex items-start gap-2">
          <%= lucide_icon "scan-line", class: "w-4 h-4 shrink-0 mt-0.5 text-primary" %>
          <span>扫描上方二维码</span>
        </li>
        <li class="flex items-start gap-2">
          <%= lucide_icon "check-circle", class: "w-4 h-4 shrink-0 mt-0.5 text-primary" %>
          <span>确认支付后页面自动跳转</span>
        </li>
      </ol>

      <%= link_to wechat_pay_order_new_path, class: "text-xs text-muted hover:text-secondary transition-default" do %>
        重新生成二维码
      <% end %>
    </div>
  </div>
</div>
