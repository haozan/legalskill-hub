<div class="container-sm py-16">
  <div class="card text-center">
    <div class="card-header border-b border-[hsl(var(--color-border))]">
      <div class="flex items-center justify-center gap-2 mb-2">
        <%= lucide_icon "shield-check", class: "w-6 h-6 text-primary" %>
        <h1 class="text-xl font-semibold text-primary">申请试用</h1>
      </div>
      <p class="text-sm text-secondary">青狮法律技能平台 · 专业法律技能资源</p>
    </div>

    <div class="card-body space-y-6">
      <% if @existing_paid %>
        <div class="alert-success">
          <div class="flex items-center gap-2 justify-center">
            <%= lucide_icon "check-circle", class: "w-5 h-5" %>
            <span>您已完成支付，可以使用平台全部功能</span>
          </div>
        </div>
        <%= link_to root_path, class: "btn-primary btn-md w-full" do %>
          <%= lucide_icon "home", class: "w-4 h-4" %>
          <span>返回首页</span>
        <% end %>
      <% else %>
        <div class="space-y-2">
          <p class="text-muted text-sm">完成支付即可解锁平台试用权限</p>
          <div class="flex items-baseline justify-center gap-1">
            <span class="text-4xl font-bold text-primary font-mono">¥<%= sprintf("%.2f", @amount_yuan) %></span>
          </div>
          <p class="text-xs text-muted">一次性试用费用 · 无隐藏收费</p>
        </div>

        <%= button_to wechat_pay_order_create_path, method: :post, class: "btn-primary btn-lg w-full font-mono tracking-widest" do %>
          <%= lucide_icon "qr-code", class: "w-5 h-5" %>
          <span>微信扫码支付</span>
        <% end %>
      <% end %>
    </div>
  </div>
</div>
