<% content_for :title, @skill_category.name %>

<div class="container-lg">
  <div class="mb-6">
    <div class="flex items-center space-x-4">
      <%= link_to admin_skill_categories_path, class: "btn-ghost text-sm py-1 px-3" do %>
        <%= lucide_icon "arrow-left", class: "w-4 h-4 mr-2" %>
        返回技能分类列表
      <% end %>
    </div>

    <div class="mt-4 flex items-center justify-between">
      <h1 class="text-3xl font-bold text-gray-900 dark:text-gray-50"><%= @skill_category.name %></h1>

      <div class="flex items-center space-x-3">
        <%= link_to edit_admin_skill_category_path(@skill_category.id), class: "btn-primary" do %>
          <%= lucide_icon "pencil", class: "w-5 h-5 mr-2" %>
          编辑
        <% end %>

        <%= link_to admin_skill_category_path(@skill_category.id),
            data: { turbo_method: :delete, turbo_confirm: "确定删除「#{@skill_category.name}」分类吗？" },
            class: "btn-danger" do %>
          <%= lucide_icon "trash-2", class: "w-5 h-5 mr-2" %>
          删除
        <% end %>
      </div>
    </div>
  </div>

  <div class="card bg-gray-50 dark:bg-gray-900 border border-gray-200 dark:border-gray-700">
    <div class="card-body">
      <div class="space-y-6">
        <div>
          <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-2">分类名称</label>
          <div class="text-lg font-medium text-gray-900 dark:text-gray-100"><%= @skill_category.name %></div>
        </div>

        <div>
          <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-2">Slug</label>
          <div class="text-sm font-mono text-gray-600 dark:text-gray-300"><%= @skill_category.slug %></div>
        </div>

        <div>
          <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-2">描述</label>
          <div class="prose prose-gray dark:prose-invert max-w-none">
            <%= simple_format(@skill_category.description) %>
          </div>
        </div>

        <div>
          <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-2">关联技能数量</label>
          <div class="text-lg font-semibold text-gray-900 dark:text-gray-100"><%= @skill_category.skills.count %> 个技能</div>
        </div>

        <div class="pt-6 border-t border-gray-200 dark:border-gray-600">
          <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
            <div>
              <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-2">ID</label>
              <div class="text-sm font-mono text-gray-900 dark:text-gray-100"><%= @skill_category.id %></div>
            </div>
            <div>
              <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-2">创建时间</label>
              <div class="text-sm text-gray-600 dark:text-gray-400">
                <%= @skill_category.created_at.strftime("%Y年%m月%d日 %H:%M") %>
                <span class="text-gray-400">（<%= time_ago_in_words(@skill_category.created_at) %>前）</span>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>
