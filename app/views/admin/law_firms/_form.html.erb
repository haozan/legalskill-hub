<%= form_with model: [:admin, law_firm], class: "space-y-6" do |f| %>
  <% if law_firm.errors.any? %>
    <div class="bg-red-50 border border-red-200 rounded p-4 text-sm text-red-700">
      <% law_firm.errors.full_messages.each do |msg| %>
        <p><%= msg %></p>
      <% end %>
    </div>
  <% end %>

  <div>
    <label class="form-label">律所名称 <span class="text-red-500">*</span></label>
    <%= f.text_field :name, class: "form-input w-full", placeholder: "如：北京大成律师事务所" %>
  </div>

  <div>
    <label class="form-label">省份</label>
    <%= f.text_field :province, class: "form-input w-full", placeholder: "如：广东省" %>
  </div>

  <div>
    <label class="form-label">城市</label>
    <%= f.text_field :city, class: "form-input w-full", placeholder: "如：深圳市" %>
  </div>

  <div>
    <label class="form-label">区/县</label>
    <%= f.text_field :district, class: "form-input w-full", placeholder: "如：南山区" %>
  </div>

  <div class="flex gap-3 pt-2">
    <%= f.submit law_firm.new_record? ? "创建律所" : "保存修改", class: "btn-primary" %>
    <%= link_to "取消", admin_law_firms_path, class: "btn-ghost" %>
  </div>
<% end %>
